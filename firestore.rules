rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHATPMT SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a strict path-based ownership model. Security is enforced by 
     * leveraging the user's unique identifier (UID) directly within the document paths. 
     * This approach, known as Authorization Independence, ensures that access decisions 
     * are fast, atomic, and do not require expensive cross-document lookups (get() calls).
     *
     * Data Structure:
     * - /userProfiles/{userId}: Private profile data for each user.
     * - /users/{userId}/prompts/{promptId}: Private history of AI-generated prompts.
     * - /users/{userId}/subscriptions/{subId}: Private subscription and credit records.
     * - /subscriptionPlans/{planId}: Publicly available catalog of plans and credit packs.
     */

    // --- Helper Functions ---

    /** Checks if the request is made by an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Combined check for update/delete operations: 
     * Verifies the user owns the path AND the document currently exists. 
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile collection. Allows users to manage their own profile.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
                    && request.resource.data.id == userId;
      
      allow update: if isExistingOwner(userId) 
                    && request.resource.data.id == resource.data.id;
      
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for user-specific AI prompts. Ensures private prompt history.
     */
    match /users/{userId}/prompts/{promptId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
                    && request.resource.data.userId == userId;
      
      allow update: if isExistingOwner(userId) 
                    && request.resource.data.userId == resource.data.userId;
      
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the public subscription plans catalog.
     */
    match /subscriptionPlans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if false; 
    }

    /**
     * @description Rules for tracking individual user subscriptions and purchases.
     */
    match /users/{userId}/subscriptions/{userSubscriptionId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
                    && request.resource.data.userId == userId;
      
      allow update: if isExistingOwner(userId) 
                    && request.resource.data.userId == resource.data.userId;
      
      allow delete: if isExistingOwner(userId);
    }
  }
}
